{
  "name": "mogause",
  "version": "1.0.0",
  "description": "mogause — autonomous AI agents on Stellar that discover and pay for premium API tools using x402 HTTP 402 micropayments",
  "private": true,
  "workspaces": [
    "backend",
    "agent",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:agent": "cd agent && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test:client": "cd agent && npm run test:client",
    "install:all": "cd backend && npm install && cd ../agent && npm install && cd ../frontend && npm install"
  },
  "keywords": [
    "x402",
    "stellar",
    "ai-agents",
    "blockchain",
    "micropayments",
    "http402",
    "web3"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
