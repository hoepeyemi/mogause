# mogause — single env file for Docker Compose (repo root)
#
# Copy to docker.env and fill in secrets:
#   cp docker.env.example docker.env
#
# Start stack (loads this file for compose substitution + container env):
#   docker compose --env-file docker.env up -d --build
#   npm run docker:up
#
# ─────────────────────────────────────────────────────────────────────────────
# Compose (host ports)
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_PUBLISH_PORT=4002
FRONTEND_PUBLISH_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Storage (Docker volumes / tmpfs — see docker-compose.yml)
# ─────────────────────────────────────────────────────────────────────────────
# Persistent (named volumes, kept across container recreate):
#   backend  → /data            (MOGAUSE_DATA_DIR; durable files / future exports)
#   frontend → /opt/run/data   (optional static assets or files you add)
# Ephemeral (tmpfs, cleared when the container is removed):
#   frontend → /opt/run/.next/cache (Next fetch/image cache — 512M)
#   backend, frontend, agent → /tmp/mogause (scratch; 256M / 256M / 128M)
MOGAUSE_DATA_DIR=/data

# ─────────────────────────────────────────────────────────────────────────────
# Frontend — NEXT_PUBLIC_* (baked in at image build time; must be a browser-reachable API URL)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4002
NEXT_PUBLIC_STELLAR_NETWORK=stellar:testnet
NEXT_PUBLIC_SERVER_ADDRESS=
NEXT_PUBLIC_AGENT_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Backend — server & CORS (CORS_ORIGIN must match where users open the UI)
# ─────────────────────────────────────────────────────────────────────────────
PORT=4002
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Stellar
STELLAR_NETWORK=stellar:testnet
HORIZON_URL=https://horizon-testnet.stellar.org
# SKIP_HORIZON_TX_VERIFY=true
EXPLORER_BASE=https://stellar.org/explorer
SERVER_ADDRESS=G...
AGENT_PRIVATE_KEY=S...
# MPP_SECRET_KEY=
# STELLAR_RECIPIENT=G...

# AI
GROQ_API_KEY=
GEMINI_API_KEY=

# Sponsor / onboarding (optional)
SPONSOR_SECRET_KEY=
CHANNEL_SECRET_KEYS=
USDC_ISSUER=
MAX_TX_FEE=10000
MAX_STARTING_BALANCE=1
CHANNEL_RESERVATION_TTL_MS=30000

# Ops
SIMULATION_MODE=false
RATE_LIMIT_PER_IP_WINDOW_MS=3600000
RATE_LIMIT_PER_IP_MAX=5
CONTRACT_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# CLI agent container — same keys as above where shared; AGENT_SERVER_URL uses Docker DNS
# ─────────────────────────────────────────────────────────────────────────────
# Inside Compose, backend service hostname is "backend" (do not use localhost here).
AGENT_SERVER_URL=http://backend:4002
NETWORK=testnet
