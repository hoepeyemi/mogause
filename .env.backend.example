# Root deployment env for backend container.
# Server path example: /home/ubuntu/mogause/.env.backend
# This file is mounted to /app/.env inside Dockerfile.backend container.

PORT=4002
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

STELLAR_NETWORK=stellar:testnet
HORIZON_URL=https://horizon-testnet.stellar.org
EXPLORER_BASE=https://stellar.org/explorer
# SKIP_HORIZON_TX_VERIFY=true

SERVER_ADDRESS=G...
AGENT_PRIVATE_KEY=S...
# MPP_SECRET_KEY=
# STELLAR_RECIPIENT=G...

GROQ_API_KEY=
GEMINI_API_KEY=

SPONSOR_SECRET_KEY=
CHANNEL_SECRET_KEYS=S...,S...,S...
USDC_ISSUER=GBBD...

MAX_TX_FEE=10000
MAX_STARTING_BALANCE=1
CHANNEL_RESERVATION_TTL_MS=30000

SIMULATION_MODE=false
RATE_LIMIT_PER_IP_WINDOW_MS=3600000
RATE_LIMIT_PER_IP_MAX=5

CONTRACT_ADDRESS=
