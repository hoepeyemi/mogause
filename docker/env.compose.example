# Optional: copy to repo root as `.env.compose` and run:
#   docker compose --env-file .env.compose up --build
#
# Published ports (host)
BACKEND_PUBLISH_PORT=4002
FRONTEND_PUBLISH_PORT=3000
#
# --- Frontend build-time (NEXT_PUBLIC_* — baked into the Next.js bundle) ---
# URL the browser uses to reach the API (host + published backend port).
NEXT_PUBLIC_API_URL=http://localhost:4002
# Backend Stellar public key (G...) for WalletInfo / demos — optional
NEXT_PUBLIC_SERVER_ADDRESS=
# Dev-only; do not set in production images
NEXT_PUBLIC_AGENT_PRIVATE_KEY=
# stellar:testnet | stellar:pubnet
NEXT_PUBLIC_STELLAR_NETWORK=stellar:testnet
#
# --- Agent container → backend (Docker DNS service name) ---
AGENT_SERVER_URL=http://backend:4002
#
# Backend and agent secrets are NOT listed here — use:
#   backend/.env   (see backend/.env.example)
#   agent/.env     (see agent/.env.example)
