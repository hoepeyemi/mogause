# Root deployment env for frontend app (if you deploy frontend separately).
# Server path example: /home/ubuntu/mogause/.env.frontend

NEXT_PUBLIC_API_URL=http://localhost:4002
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_EXPLORER_URL=https://stellar.org/explorer
NEXT_PUBLIC_SERVER_ADDRESS=G...
NEXT_PUBLIC_AGENT_PRIVATE_KEY=
NEXT_PUBLIC_FEATURE_A2A=true
NEXT_PUBLIC_FEATURE_PROTOCOL_TRACE=true
NEXT_PUBLIC_FEATURE_STRESS_TEST=true
NEXT_PUBLIC_ENABLE_WALLET_CONNECT=true
NEXT_PUBLIC_ENABLE_HARDWARE_WALLETS=true
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_REACT_STRICT_MODE=false
NEXT_PUBLIC_SESSION_TIMEOUT=30
