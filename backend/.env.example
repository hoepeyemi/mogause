# mogause Backend Environment Configuration
# Copy this file to .env and update with your values

# ═══════════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════════

PORT=4002
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# Stellar Network Configuration
# ═══════════════════════════════════════════════════════════════

# Network: stellar:testnet or stellar:pubnet
STELLAR_NETWORK=stellar:testnet
HORIZON_URL=https://horizon-testnet.stellar.org
# When unset, the server checks Horizon before attaching StellarExpert links to payment logs (avoids "tx not found" when network env is wrong).
# SKIP_HORIZON_TX_VERIFY=true

EXPLORER_BASE=https://stellar.org/explorer

# The public key of the backend agent wallet (Sponsor)
SERVER_ADDRESS=G...

# The private key of the backend agent wallet (MPP shared secret for charge verification)
# Set either AGENT_PRIVATE_KEY or MPP_SECRET_KEY — both are accepted.
AGENT_PRIVATE_KEY=S...
# MPP_SECRET_KEY=

# Payment recipient (defaults to public key derived from AGENT_PRIVATE_KEY if unset or invalid)
# STELLAR_RECIPIENT=G...

# ═══════════════════════════════════════════════════════════════
# AI Model Configuration
# ═══════════════════════════════════════════════════════════════

# Groq API Key (Llama 3.3)
GROQ_API_KEY=

# Google Gemini API Key (Fallback)
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Agent Onboarding & Sponsorship (Sponsor Service)
# ═══════════════════════════════════════════════════════════════

# Sponsor account secret key (usually same as AGENT_PRIVATE_KEY for simple setups)
SPONSOR_SECRET_KEY=

# Comma-separated channel account keys for concurrency
CHANNEL_SECRET_KEYS=S...,S...,S...

# USDC Asset Issuer public key (Testnet)
USDC_ISSUER=GBBD...

# Max transaction fee in stroops (1 stroop = 0.0000001 XLM)
MAX_TX_FEE=10000

# Max starting balance for new agents in stroops
MAX_STARTING_BALANCE=1

# TTL for unredeemed /create responses (30s)
CHANNEL_RESERVATION_TTL_MS=30000

# ═══════════════════════════════════════════════════════════════
# Operational Settings
# ═══════════════════════════════════════════════════════════════

# Simulation Mode: true = bypass real payments, false = require XLM
SIMULATION_MODE=false

# IP Rate limiting for onboarding
RATE_LIMIT_PER_IP_WINDOW_MS=3600000
RATE_LIMIT_PER_IP_MAX=5

# Contract Address for Soroban Agent Registry
CONTRACT_ADDRESS=

